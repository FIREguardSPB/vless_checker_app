<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VLESS Checker"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textStyle="bold" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Проверка и сравнение ссылок из локального файла или из удалённых списков XRayCheck: поиск самой быстрой рабочей ссылки, полная проверка с временем отклика, импорт файла и фоновая автопроверка."
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/noteText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Проверка легковесная: tcp/none — TCP connect, tls — TCP + TLS handshake, reality — только TCP connect. По нажатию на плашку результат копируется в буфер в очищенном валидном формате для вставки в v2RayTun. Долгое нажатие — попытка открыть конфиг в совместимом VPN-клиенте."
            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Источник списка"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <Spinner
            android:id="@+id/sourceSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/refreshSourceButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Подтянуть выбранный список" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/importButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Импортировать локальный список из файла" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Список ссылок, по одной на строку"
            app:boxBackgroundMode="outline">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/linksEditText"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:gravity="top|start"
                android:inputType="textMultiLine|textNoSuggestions"
                android:maxLines="16"
                android:minLines="10"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="vertical" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/autoCheckSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Автопроверка по таймеру" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/autoCheckHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Интервал автопроверки"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <Spinner
            android:id="@+id/intervalSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/deleteDeadSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="После полной проверки удалить нерабочие ссылки из текущего списка на экране" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/checkFirstButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Проверить и скопировать самую быструю" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/checkAllButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Проверить все и показать отклик" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/importFastestVpnButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:enabled="false"
            android:text="Импортировать fastest в VPN-клиент" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/openVpnSettingsButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Открыть системные настройки VPN" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/startVpnButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Старт v2RayTun" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/stopVpnButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Стоп v2RayTun" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/restartVpnButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Рестарт v2RayTun" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textIsSelectable="true" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/checkedResultsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/checked_results_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:visibility="gone" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/checkedResultsHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/checked_results_hint"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/checkedResultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
